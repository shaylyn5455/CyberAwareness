<Window x:Class="CyberAwareness_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aries-X // Sentinel" Height="600" Width="1000" Background="#050505">
    <Grid>
        <Border Background="#1a0a00" Height="60" VerticalAlignment="Top" BorderBrush="#ff4500" BorderThickness="0,0,0,2">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="ARIES-X // CORE" Foreground="#ff4500" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center"/>
                <TextBlock Text="OPERATOR: SHAYLYN" Foreground="#00ccff" FontSize="12" HorizontalAlignment="Center" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <ScrollViewer x:Name="ChatScroller" Margin="20,80,20,100" VerticalScrollBarVisibility="Auto">
            <ItemsControl x:Name="ChatDisplay">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="10" Margin="5" Padding="15" MaxWidth="600" 
                                HorizontalAlignment="{Binding Alignment}" 
                                Background="{Binding BubbleColor}" BorderBrush="#333" BorderThickness="1">
                            <TextBlock Text="{Binding Message}" Foreground="White" TextWrapping="Wrap" FontSize="14" FontFamily="Consolas"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <Grid Height="60" VerticalAlignment="Bottom" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="UserInput" Background="#111" Foreground="#ff4500" BorderBrush="#ff4500" 
                     FontSize="16" VerticalContentAlignment="Center" Padding="10" 
                     KeyDown="UserInput_KeyDown"/>
            <Button Grid.Column="1" Content="EXECUTE" Background="#ff4500" Foreground="White" 
                    FontWeight="Bold" Margin="10,0,0,0" Click="Execute_Click"/>
        </Grid>
    </Grid>
</Window>