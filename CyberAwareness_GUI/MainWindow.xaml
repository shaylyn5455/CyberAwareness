<Window x:Class="CyberAwareness_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aries-X // Sentinel" Height="650" Width="450" Background="#05080A">
    <Window.Resources>
        <DropShadowEffect x:Key="OrangeGlow" Color="#FF4500" BlurRadius="15" ShadowDepth="0" Opacity="0.8"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" CornerRadius="12" Margin="0,0,0,15" Background="#101520" BorderBrush="#FF4500" BorderThickness="1" Effect="{StaticResource OrangeGlow}">
            <StackPanel Margin="12">
                <TextBlock Text="ARIES-X // CORE" FontSize="26" FontWeight="Black" Foreground="#FF4500" HorizontalAlignment="Center" FontFamily="Consolas"/>
                <TextBlock Text="OPERATOR: SHAYLYN" FontSize="12" Foreground="#00D4FF" HorizontalAlignment="Center" FontWeight="Bold"/>
            </StackPanel>
        </Border>

        <Border x:Name="LoginOverlay" Grid.Row="1" Panel.ZIndex="10" Background="#0A0A0A" BorderBrush="#FF4500" BorderThickness="1" CornerRadius="8">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="SECURE ACCESS REQUIRED" Foreground="#FF4500" Margin="0,0,0,10" HorizontalAlignment="Center"/>
                <PasswordBox x:Name="PassInput" Width="200" Height="40" Background="#1A1A1A" Foreground="White" BorderBrush="#FF4500" VerticalContentAlignment="Center"/>
                <Button Content="LOGIN" Margin="0,20,0,0" Width="100" Height="35" Background="#FF4500" Foreground="White" Click="AuthButton_Click"/>
            </StackPanel>
        </Border>

        <ListBox x:Name="ChatHistory" Grid.Row="1" Background="Transparent" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ListBoxItem">
                                <Border x:Name="Bubble" CornerRadius="15" Padding="12" Margin="8,4" MaxWidth="300" HorizontalAlignment="Left" Background="#1A202C" BorderBrush="#303F5F" BorderThickness="1">
                                    <ContentPresenter />
                                </Border>
                                <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding IsUser}" Value="True">
                                        <Setter TargetName="Bubble" Property="HorizontalAlignment" Value="Right"/>
                                        <Setter TargetName="Bubble" Property="Background" Value="#004D66"/>
                                        <Setter TargetName="Bubble" Property="BorderBrush" Value="#00D4FF"/>
                                    </DataTrigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ListBox.ItemContainerStyle>
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <TextBlock Text="{Binding Message}" Foreground="White" TextWrapping="Wrap" FontSize="13" FontFamily="Segoe UI Semibold"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <Grid Grid.Row="2" Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox x:Name="UserInput" Height="48" Background="#0D1117" Foreground="White" BorderBrush="#FF4500" BorderThickness="1" Padding="10,0" VerticalContentAlignment="Center" CaretBrush="#00D4FF" FontSize="14"/>
            <Button Grid.Column="1" Content="EXECUTE" Width="90" Margin="10,0,0,0" Background="#FF4500" Foreground="White" FontWeight="Bold" Click="SendButton_Click"/>
        </Grid>
    </Grid>
</Window>