<Window x:Class="CyberAwareness_GUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Aries-X // Sentinel" Height="600" Width="1000" Background="#050505">

    <Grid>
        <!-- Top Status Bar & Operations Header -->
        <Border Background="#1a0a00" Height="60" VerticalAlignment="Top" BorderBrush="#ff4500" BorderThickness="0,0,0,2">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="ARIES-X // CORE" Foreground="#ff4500" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#ff4500" BlurRadius="8" ShadowDepth="0" Opacity="0.7"/>
                    </TextBlock.Effect>
                </TextBlock>
                <TextBlock Text="OPERATOR: SHAYLYN" Foreground="#00ccff" FontSize="12" HorizontalAlignment="Center" FontWeight="SemiBold"/>
            </StackPanel>
        </Border>

        <!-- Conversational Output Feed Window -->
        <ScrollViewer x:Name="ChatScroller" Margin="20,80,20,100" VerticalScrollBarVisibility="Auto" CanContentScroll="False">
            <ItemsControl x:Name="ChatDisplay">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border CornerRadius="10" Margin="5" Padding="15" MaxWidth="650" 
                                HorizontalAlignment="{Binding Alignment}" 
                                Background="{Binding BubbleColor}" BorderBrush="#333" BorderThickness="1">
                            <TextBlock Text="{Binding Message}" Foreground="White" TextWrapping="Wrap" FontSize="14" FontFamily="Consolas" LineHeight="20"/>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Input Terminal Panel -->
        <Grid Height="60" VerticalAlignment="Bottom" Margin="20,0,20,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="120"/>
            </Grid.ColumnDefinitions>

            <TextBox x:Name="UserInput" Background="#111" Foreground="#ff4500" BorderBrush="#ff4500" 
                     FontSize="16" VerticalContentAlignment="Center" Padding="10" FontFamily="Consolas"
                     KeyDown="UserInput_KeyDown"/>

            <Button Grid.Column="1" Content="EXECUTE" Background="#ff4500" Foreground="White" 
                    FontWeight="Bold" FontSize="14" FontFamily="Consolas" Margin="10,0,0,0" 
                    Click="Execute_Click">
                <Button.Resources>
                    <!-- Simple style override to remove default Windows hover gloss looks -->
                    <Style TargetType="Button">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Window>